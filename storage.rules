rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function ownsProfilePhoto(fileName) {
      return isSignedIn() && fileName == request.auth.uid + ".jpg";
    }

    match /profilePhotos/{fileName} {
      allow read, write: if ownsProfilePhoto(fileName);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
